<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="4dp"
    app:cardBackgroundColor="@color/surface"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <!-- Thumbnail -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/violationThumbnail"
            android:layout_width="80dp"
            android:layout_height="60dp"
            android:scaleType="centerCrop"
            android:background="@color/background"
            app:shapeAppearanceOverlay="@style/RoundedCorners" />

        <!-- Details -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:id="@+id/violationType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No Helmet"
                android:textColor="@color/violation_helmet"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/violationTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Jan 21, 10:30"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Confidence & Status -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">

            <TextView
                android:id="@+id/violationConfidence"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="95%"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <View
                android:id="@+id/syncStatus"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_marginTop="8dp"
                android:layout_gravity="end"
                android:background="@drawable/circle_pending" />
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
