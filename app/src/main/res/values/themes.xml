<resources>
    <!-- Theme -->
    <style name="Theme.SmartRoad" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/accent</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="android:statusBarColor">@color/status_bar</item>
        <item name="android:navigationBarColor">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOnPrimary">@color/background</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
    </style>
    
    <!-- Splash Theme -->
    <style name="Theme.SmartRoad.Splash" parent="Theme.SmartRoad">
        <item name="android:windowBackground">@drawable/splash_background</item>
    </style>
    
    <!-- Dialog Theme -->
    <style name="Theme.SmartRoad.Dialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="android:background">@color/surface</item>
        <item name="colorSurface">@color/surface</item>
    </style>

    <!-- Base Widget Style -->
    <style name="Widget.SmartRoad" parent="@android:style/Widget" />
    
    <!-- Card Style -->
    <style name="Widget.SmartRoad.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/card_background</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">4dp</item>
    </style>
    
    <!-- Primary Button -->
    <style name="Widget.SmartRoad.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="android:textColor">@color/background</item>
        <item name="backgroundTint">@color/primary</item>
        <item name="cornerRadius">8dp</item>
    </style>
    
    <!-- Outlined Button -->
    <style name="Widget.SmartRoad.Button.Outlined" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textColor">@color/primary</item>
        <item name="strokeColor">@color/primary</item>
        <item name="cornerRadius">8dp</item>
    </style>
    
    <!-- Text Styles -->
    <style name="TextAppearance.SmartRoad.Headline" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>
    
    <style name="TextAppearance.SmartRoad.Title" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">@color/text_primary</item>
    </style>
    
    <style name="TextAppearance.SmartRoad.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/text_secondary</item>
    </style>
    
    <style name="TextAppearance.SmartRoad.Label" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:textColor">@color/text_secondary</item>
    </style>
    
    <!-- Stat Counter -->
    <style name="Widget.SmartRoad.StatCounter" parent="Widget.SmartRoad">
        <item name="android:textSize">28sp</item>
        <item name="android:textStyle">bold</item>
    </style>
    
    <!-- Violation Badge -->
    <style name="Widget.SmartRoad.ViolationBadge" parent="Widget.SmartRoad">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textAllCaps">true</item>
    </style>
</resources>
